{
  "name": "mcp-codemode",
  "version": "0.0.0",
  "description": "Generic Code Mode MCP toolkit: expose huge API surfaces to agents as two tools (search + execute) running in Cloudflare dynamic Worker isolates",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260625.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0",
    "wrangler": "4.105.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14"
}
